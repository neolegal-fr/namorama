# ─── Base de données ────────────────────────────────────────────────────────
# MariaDB lancée via docker-compose (infra/docker-compose.yml)
DATABASE_URL=mariadb://admin:admin_password@localhost:3306/namorama

# ─── Keycloak ───────────────────────────────────────────────────────────────
# Realm pré-configuré, lancé via docker-compose
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=namorama
KEYCLOAK_CLIENT_ID=namorama-api
KEYCLOAK_SECRET=your-keycloak-client-secret

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Obligatoire — génération de noms et mots-clés
OPENAI_API_KEY=sk-...

# ─── Serveur ────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:4200

# ─── Stripe (optionnel en dev local) ────────────────────────────────────────
# Laisser vide pour désactiver les paiements
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PACK_DECOUVERTE_PRICE_ID=price_...
STRIPE_PACK_PRO_PRICE_ID=price_...
STRIPE_PACK_MAX_PRICE_ID=price_...
