# ─── Base de données ────────────────────────────────────────────────────────
POSTGRES_USER=namespoter
POSTGRES_PASSWORD=changeme_strong_password

# ─── Keycloak ───────────────────────────────────────────────────────────────
KEYCLOAK_HOSTNAME=auth.neolegal.fr
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_strong_password
