# ─── Base de données ────────────────────────────────────────────────────────
POSTGRES_USER=namespoter
POSTGRES_PASSWORD=changeme_strong_password

# ─── Keycloak ───────────────────────────────────────────────────────────────
# Nom d'hôte public de Keycloak (sans https://)
KEYCLOAK_HOSTNAME=auth.yourdomain.com
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_strong_password
# Secret du client namespoter-api (depuis Keycloak > Clients > namespoter-api > Credentials)
KEYCLOAK_SECRET=changeme_keycloak_client_secret

# ─── URLs publiques ─────────────────────────────────────────────────────────
# URL publique de l'API (accessible depuis le navigateur des utilisateurs)
API_URL=https://api.yourdomain.com
# URL publique de Keycloak (accessible depuis le navigateur et depuis l'API)
KEYCLOAK_URL=https://auth.yourdomain.com
# URL publique du frontend (pour CORS dans l'API)
FRONTEND_URL=https://namespoter.yourdomain.com

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_ESSENTIAL_PRICE_ID=price_...
STRIPE_PACK_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
